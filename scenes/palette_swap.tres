[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_b8g0w"]
size = Vector2(540, 540)
expression = "vec2 new_uv = vec2(0, 0);

for (int i = 0; i < colours_count; i++) {
	float u = (float(i) + 0.5) / float(colours_count);
	float v = 0.5;
	vec2 uv = vec2(u, v);
	vec4 original_palette_colour = texture(original_palette, uv);
	float dist = distance(colour, original_palette_colour);
	
	if (dist == 0.0) {
		new_uv = uv;
	}
}

new_colour = texture(new_palette, new_uv);"

